{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "サブスクリプション価格ウォッチ (index.html)",
      "runtimeExecutable": "powershell",
      "runtimeArgs": [
        "-ExecutionPolicy", "Bypass",
        "-File", "serve.ps1",
        "-Port", "3000"
      ],
      "cwd": "${workspaceFolder}",
      "port": 3000
    },
    {
      "name": "編集ツール (edit.html)",
      "runtimeExecutable": "powershell",
      "runtimeArgs": [
        "-ExecutionPolicy", "Bypass",
        "-File", "serve.ps1",
        "-Port", "3001"
      ],
      "cwd": "${workspaceFolder}",
      "port": 3001
    }
  ]
}
